# PatternScout Environment Configuration

# Database
DATABASE_URL=sqlite:///./patternscout.db

# Google Custom Search API
# Get API key: https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=your_google_api_key_here
# Get CX (Search Engine ID): https://programmablesearchengine.google.com/controlpanel/create
GOOGLE_CX=your_search_engine_id_here

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=qwen3.5:4b
OLLAMA_TEXT_MODEL=qwen3.5:4b
OLLAMA_USE_VISION=false

# Storage
SCREENSHOTS_DIR=./screenshots

# API
API_V1_STR=/api/v1

# Frontend (Streamlit)
API_URL=http://localhost:8000
